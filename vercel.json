{
    "services": {
        "frontend": {
            "root": ".",
            "framework": "vite",
            "env": {
                "VITE_API_URL": "https://harvey-backend.vercel.app"
            }
        },
        "backend": {
            "root": "backend"
        }
    },
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}